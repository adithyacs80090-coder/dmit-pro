# ============================================================
# DMIT Pro — Environment Configuration
# Copy this file to `.env` and fill in your real values
# NEVER commit `.env` to git
# ============================================================

# --------------------------------------------------
# Database (MySQL)
# --------------------------------------------------
MYSQL_ROOT_PASSWORD=change_this_root_password_too
MYSQL_USER=dmit
MYSQL_PASSWORD=change_this_to_a_strong_random_password
MYSQL_DATABASE=dmit_pro

# Format: mysql://user:password@host:port/database
# For Docker: host is the service name 'db'
DATABASE_URL=mysql://dmit:change_this_to_a_strong_random_password@db:3306/dmit_pro

# --------------------------------------------------
# Cache (Redis)
# --------------------------------------------------
REDIS_URL=redis://redis:6379

# --------------------------------------------------
# Security — JWT Tokens
# Generate with: openssl rand -base64 64
# Must be at least 32 characters
# --------------------------------------------------
JWT_SECRET=your-jwt-secret-min-32-chars-change-this
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-this

# --------------------------------------------------
# Razorpay Payment Gateway
# Get from: https://dashboard.razorpay.com/app/api-keys
# --------------------------------------------------
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=generate-a-random-string-for-webhook-verification

# --------------------------------------------------
# Email (Resend)
# Get from: https://resend.com/api-keys
# --------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@dmitpro.com

# --------------------------------------------------
# Application URLs
# --------------------------------------------------
NODE_ENV=production
PORT=4000
FRONTEND_URL=https://dmitpro.in
API_URL=https://api.dmitpro.in

# --------------------------------------------------
# Logging
# --------------------------------------------------
LOG_LEVEL=info
